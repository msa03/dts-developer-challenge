# Ensure consistent line endings across platforms

# Default: normalise all text files to LF in the repo
* text=auto eol=lf

# Explicitly binary — never touch line endings
*.cjs         binary
*.jar         binary
*.png         binary
*.jpg         binary
*.ico         binary
*.zip         binary
*.gz          binary
*.exec        binary

# Shell scripts must always be LF
gradlew       text eol=lf
*.sh          text eol=lf

# Config / source files — force LF
*.yml         text eol=lf
*.yaml        text eol=lf
*.json        text eol=lf
*.ts          text eol=lf
*.js          text eol=lf
*.njk         text eol=lf
*.sql         text eol=lf
*.gradle      text eol=lf
*.properties  text eol=lf
Dockerfile    text eol=lf
