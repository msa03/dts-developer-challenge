{% extends "template.njk" %}

{% block content %}
  <div class="govuk-width-container">
    <main class="govuk-main-wrapper">
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
          <h1 class="govuk-heading-xl">HMCTS task manager</h1>
          <p class="govuk-body-l">
            A simple task management service for caseworkers to create, review and complete work in one place.
          </p>
          <p class="govuk-body">
            Use the task list to add new work, update task status and remove tasks that are no longer needed.
          </p>
          <a href="/tasks" class="govuk-button">View tasks</a>
        </div>
      </div>
    </main>
  </div>
{% endblock %}
